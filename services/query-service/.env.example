# query-service config. Compose injects these from the root .env; for local
# `uvicorn` copy this to services/query-service/.env.

# Shared (documind_common reads these too)
OPENAI_API_KEY=sk-replace-me
LLM_PROVIDER=openai
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
TEMPERATURE=0.2
VECTOR_COLLECTION=documind_chunks
TOP_K=4

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=documind
POSTGRES_USER=documind
POSTGRES_PASSWORD=documind

# query-service owns this
MONGO_URI=mongodb://localhost:27017
MONGO_DB=documind

# Hybrid retrieval + reranking (Day 2)
HYBRID_ENABLED=true
RETRIEVAL_CANDIDATES=20
RERANKER=none                       # set to "cross-encoder" after installing sentence-transformers

# Langfuse LLM observability (leave blank to disable; see docs/ai/observability.md)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
