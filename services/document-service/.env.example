# document-service config. Compose injects these from the root .env; for local
# `uvicorn` copy this to services/document-service/.env.

# Shared (documind_common reads these too)
OPENAI_API_KEY=sk-replace-me
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
VECTOR_COLLECTION=documind_chunks

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=documind
POSTGRES_USER=documind
POSTGRES_PASSWORD=documind

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
DOCUMENT_EVENTS_TOPIC=document-events
DOCUMENT_EVENTS_DLT_TOPIC=document-events.DLT
CONSUMER_GROUP=documind-ingestion

STORAGE_DIR=./storage
