# Copy to .env at the repo root. `docker compose` reads this automatically.
# NEVER commit the real .env.

# ============================================================
#  PROVIDER — the ONLY switch you need.
#  Set LLM_PROVIDER to one of:  openai | anthropic | ollama
#  The chat model, embedding model, dimensions, and a per-provider vector
#  collection are all derived automatically — and each provider keeps its own
#  collection, so you can flip back and forth with no re-index. Then restart:
#      docker compose up -d document-service query-service
# ============================================================
LLM_PROVIDER=openai

# -- openai (default): paid, highest quality --
OPENAI_API_KEY=sk-replace-me
# OPENAI_BASE_URL=                       # optional: point at a compatible endpoint

# -- anthropic (chat only; embeddings still use OpenAI, so set OPENAI_API_KEY too) --
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# -- ollama (FREE / OFFLINE, no key): run `make ollama-up` first, then just --
# LLM_PROVIDER=ollama
#   ...that's it. See docs/ai/local-ollama.md.
#   Low on RAM? The default 3B chat model can get OOM-killed; use a lighter one:
# CHAT_MODEL=llama3.2:1b

# Power-user overrides (normally leave unset — the provider profile fills these):
# CHAT_MODEL=
# EMBEDDING_MODEL=
# EMBEDDING_DIMENSIONS=
# VECTOR_COLLECTION=
# TOP_K=4

# ---- Gateway auth / rate limiting ----
JWT_SECRET=dev-secret-change-me
DEMO_USERNAME=demo
DEMO_PASSWORD=demo12345
RATE_LIMIT_PER_MINUTE=10
CORS_ORIGINS=http://localhost:5173

# ---- Hybrid retrieval + reranking (Day 2) ----
HYBRID_ENABLED=true
RERANKER=none                 # "cross-encoder" needs sentence-transformers in the image

# ---- Langfuse LLM observability (optional; `make observability`) ----
# After starting Langfuse, create a project and paste its keys here, then restart query-service.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ---- Frontend build arg (baked into the static bundle) ----
VITE_API_BASE_URL=http://localhost:8080
