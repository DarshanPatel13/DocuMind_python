# Copy to backend/.env and fill in. NEVER commit the real .env.

# ---- OpenAI (the only secret you must provide) ----
OPENAI_API_KEY=sk-replace-me

# ---- Models (provider-pluggable; see app/rag/providers.py) ----
LLM_PROVIDER=openai
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
TEMPERATURE=0.2

# To swap the chat model to Anthropic Claude, set:
# LLM_PROVIDER=anthropic
# CHAT_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...
# (embeddings stay on OpenAI — Anthropic has no embeddings API)

# ---- Postgres (metadata + pgvector). Hosts default to localhost for
#      local `uvicorn`; docker-compose overrides them to service names. ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=documind
POSTGRES_USER=documind
POSTGRES_PASSWORD=documind

# ---- MongoDB (conversation history) ----
MONGO_URI=mongodb://localhost:27017
MONGO_DB=documind

# ---- Kafka ----
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ---- App ----
STORAGE_DIR=./storage
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_PER_MINUTE=10
