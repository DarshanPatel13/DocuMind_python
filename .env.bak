# Copy to .env at the repo root. `docker compose` reads this automatically.
# NEVER commit the real .env.

# ---- The only secret you MUST set ----
OPENAI_API_KEY=sk-replace-me

# ---- Optional: point the OpenAI client at a compatible endpoint ----
# OPENAI_BASE_URL=

# ---- Models (provider-pluggable; see libs/documind_common/providers.py) ----
LLM_PROVIDER=openai
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
TOP_K=4

# To swap the CHAT model to Anthropic Claude:
#   LLM_PROVIDER=anthropic
#   CHAT_MODEL=claude-sonnet-4-6
#   ANTHROPIC_API_KEY=sk-ant-...
# (embeddings stay on OpenAI — Anthropic has no embeddings API)

# ---- Gateway auth / rate limiting ----
JWT_SECRET=dev-secret-change-me
DEMO_USERNAME=demo
DEMO_PASSWORD=demo12345
RATE_LIMIT_PER_MINUTE=10
CORS_ORIGINS=http://localhost:5173

# ---- Hybrid retrieval + reranking (Day 2) ----
HYBRID_ENABLED=true
RERANKER=none                 # "cross-encoder" needs sentence-transformers in the image

# ---- Langfuse LLM observability (optional; `make observability`) ----
# After starting Langfuse, create a project and paste its keys here, then restart query-service.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000

# ---- Frontend build arg (baked into the static bundle) ----
VITE_API_BASE_URL=http://localhost:8080
